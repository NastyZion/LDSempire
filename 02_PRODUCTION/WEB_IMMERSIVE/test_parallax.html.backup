<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<title>Test Parallax – Laetsdanse</title>
<style>
  html,body{margin:0;padding:0;height:100%;overflow:hidden;font-family:sans-serif;background:#111;color:#eee;}
  .scene{position:relative;width:100vw;height:100vh;overflow:hidden;}
  .layer{
    position:absolute;top:0;left:0;width:100%;height:100%;
    background-size:cover;background-position:center;
    will-change:transform;
  }
  /* floating card over scene 3 */
  .card{
    position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);
    background:rgba(255,255,255,0.6);color:#222;padding:2rem;border-radius:12px;
    max-width:80%;text-align:center;pointer-events:none;
    font-size:1.2rem;line-height:1.4;
  }
  /* hide scrollbar */
  body::-webkit-scrollbar{display:none;}
</style>
</head>
<body>
<div class="scene">
  <div id="layer1" class="layer" data-depth="0.0" style="background-image:url('../03_ASSETS/CONCEPTS_VISUELS/SCENE_1.webp');"></div>
  <div id="layer2" class="layer" data-depth="0.2" style="background-image:url('../03_ASSETS/CONCEPTS_VISUELS/SCENE_2.webp');"></div>
  <div id="layer3" class="layer" data-depth="0.4" style="background-image:url('../03_ASSETS/CONCEPTS_VISUELS/SCENE_3.webp');"></div>
  <div id="layer4" class="layer" data-depth="0.6" style="background-image:url('../03_ASSETS/CONCEPTS_VISUELS/SCENE_4.webp');"></div>
  <div id="layer5" class="layer" data-depth="0.8" style="background-image:url('../03_ASSETS/CONCEPTS_VISUELS/SCENE_5.webp');"></div>

  <!-- floating card over the third layer -->
  <div class="card">
    Scène 3 – Stress<br>
    Texte de test pour vérifier la lisibilité sur l’image de fond.
  </div>
</div>

<!-- GSAP from CDN (free) -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
<script>
  // Grab layers
  const layers = document.querySelectorAll('.layer');
  // Mouse parallax
  function moveLayers(e){
    const mouseX = e.clientX / window.innerWidth - 0.5; // -0.5 to 0.5
    const mouseY = e.clientY / window.innerHeight - 0.5;
    layers.forEach(layer=>{
      const depth = parseFloat(layer.getAttribute('data-depth')) || 0;
      const moveX = mouseX * depth * 30; // pixels
      const moveY = mouseY * depth * 30;
      gsap.to(layer,{x:moveX, y:moveY, duration:0.5, ease:'power3.out'});
    });
  }
  window.addEventListener('mousemove', moveLayers);
  // Touch support
  window.addEventListener('touchmove', e=>{
    if(e.touches.length===1){
      const touch=e.touches[0];
      const mouseX = touch.clientX / window.innerWidth - 0.5;
      const mouseY = touch.clientY / window.innerHeight - 0.5;
      layers.forEach(layer=>{
        const depth = parseFloat(layer.getAttribute('data-depth')) || 0;
        const moveX = mouseX * depth * 30;
        const moveY = mouseY * depth * 30;
        gsap.to(layer,{x:moveX, y:moveY, duration:0.5, ease:'power3.out'});
      });
    }
  }, {passive:true});

  // Scroll transition – fade layers based on scroll progress
  function onScroll(){
    const scrollY = window.pageYOffset;
    const maxScroll = document.body.scrollHeight - window.innerHeight;
    const progress = scrollY / maxScroll; // 0 to 1
    // We'll map progress to opacity of each layer to create a cross‑fade
    // Example: layer1 visible at start, fades out; layer5 appears at end.
    layers.forEach((layer,i)=>{
      const index = i; // 0..4
      const segment = 1/(layers.length-1); // 0.25
      const start = index * segment;
      const end = start + segment;
      let opacity = 0;
      if(progress >= start && progress <= end){
        const normalized = (progress - start)/segment; // 0..1 within segment
        // make a triangle: rise then fall
        opacity = normalized < 0.5 ? normalized*2 : (1-normalized)*2;
      }
      gsap.to(layer,{opacity:opacity, duration:0.3});
    });
    // also move layers slightly for parallax scroll
    layers.forEach(layer=>{
      const depth = parseFloat(layer.getAttribute('data-depth')) || 0;
      const moveY = scrollY * depth * 0.5; // subtle vertical shift
      gsap.to(layer,{y:moveY, duration:0.5});
    });
  }
  window.addEventListener('scroll', onScroll);
  // initial call to set opacity based on start (should show first layer)
  onScroll();
</script>
</body>
</html>